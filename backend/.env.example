# AI Agents Platform - 环境变量模板
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME=ai-agents-platform
APP_ENV=development
APP_DEBUG=true

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=ai_agents_platform
DATABASE_USER=root
DATABASE_PASSWORD=changeme

# JWT 认证
JWT_SECRET_KEY=changeme-use-a-strong-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS 配置
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 日志
LOG_LEVEL=DEBUG
