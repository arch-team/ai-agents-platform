# AI Agents Platform - 环境变量模板
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME=ai-agents-platform
APP_ENV=development
APP_DEBUG=true

# 数据库配置 (本地开发直接填写, 部署环境通过 Secrets Manager 或 ECS Secrets 注入)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=ai_agents_platform
DATABASE_USER=root
DATABASE_PASSWORD=changeme

# JWT 认证 (本地开发直接填写, 部署环境通过 Secrets Manager 或 ECS Secrets 注入)
JWT_SECRET_KEY=changeme-use-a-strong-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Secrets Manager ARN — 部署环境下直接从 Secrets Manager 读取凭证 (可选)
# ECS 容器已通过 ecs.Secret.fromSecretsManager 注入时无需配置
# DB_SECRET_ARN=arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:dev/ai-agents-platform/db-credentials
# JWT_SECRET_ARN=arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:dev/ai-platform/jwt-secret

# AWS 配置 — 部署环境使用 IAM Role (ECS Task Role), 无需 AK/SK
AWS_REGION=us-east-1

# 默认管理员 — 应用启动时自动创建 (幂等，已存在则跳过)
DEFAULT_ADMIN_EMAIL=admin@ai-agents.local
DEFAULT_ADMIN_PASSWORD=Admin@2026!
DEFAULT_ADMIN_NAME=系统管理员

# 日志
LOG_LEVEL=DEBUG
