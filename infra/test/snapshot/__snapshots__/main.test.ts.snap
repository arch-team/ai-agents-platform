    "EcsDeployFailureRuleE246249E": {
      "Properties": {
        "Description": "ECS 服务部署失败时发送 SNS 告警通知",
        "EventPattern": {
          "detail": {
            "eventType": [
              "ERROR",
            ],
          },
          "detail-type": [
            "ECS Deployment State Change",
          ],
          "source": [
            "aws.ecs",
          ],
        },
        "Name": "ai-agents-platform-dev-ecs-deploy-failure",
        "State": "ENABLED",
        "Targets": [
          {
            "Arn": {
              "Ref": "AlertTopic2720D535",
            },
            "Id": "Target0",
            "InputTransformer": {
              "InputPathsMap": {
                "detail-reason": "$.detail.reason",
              },
              "InputTemplate": ""🚨 ECS 部署失败 [dev]\\n原因: <detail-reason>"",
            },
          },
        ],
      },
      "Type": "AWS::Events::Rule",
    },
