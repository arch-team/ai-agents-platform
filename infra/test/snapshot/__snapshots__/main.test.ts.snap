            },
            {
              "id": "AwsSolutions-L1",
              "is_reason_encoded": true,
              "reason": "VXNpbmcgUFlUSE9OXzNfMTMg4oCUIHRoZSBsYXRlc3QgR0EgUHl0aG9uIExhbWJkYSBydW50aW1lOyBDREsgTmFnIEwxIHJ1bGUgbWF5IGxhZyBiZWhpbmQgQ0RLIHJ1bnRpbWUgZGVmaW5pdGlvbnM=",
